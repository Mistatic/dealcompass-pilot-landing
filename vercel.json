{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/recurring-cadence?cadence=weekly_digest",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/recurring-cadence?cadence=twice_weekly",
      "schedule": "0 13 * * 2,5"
    },
    {
      "path": "/api/recurring-cadence?cadence=high_signal_only",
      "schedule": "30 13 * * *"
    }
  ]
}
